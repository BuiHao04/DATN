# Model for pretrained baseline
MODEL_ID=nielsr/layoutlmv3-finetuned-funsd

# Paths for pretrained_invoice_baseline.py
# Relative paths are resolved from project dir (src)
PRETRAIN_IMAGE_PATH=data/anh_test.jpg
PRETRAIN_OCR_DEBUG_IMAGE=outputs/ocr_boxes_pretrained.jpg
PRETRAIN_OUTPUT_JSON=outputs/pretrained_invoice_result.json

# OCR engine:
# - paddle: PaddleOCR full
# - vietocr: Paddle detect box + VietOCR recognize text
OCR_ENGINE=paddle

# Optional VietOCR config
VIETOCR_CONFIG=vgg_transformer
# VIETOCR_WEIGHTS=

# OCR preprocessing / normalization
OCR_PREPROCESS=true
OCR_DOCUMENT_NORMALIZE=true
OCR_DOCUMENT_CROP=true
OCR_DOCUMENT_MIN_AREA_RATIO=0.18
OCR_DESKEW=true
OCR_UPSCALE_MIN_SIDE=1400
OCR_UPSCALE_FACTOR=1.6
OCR_CLAHE_CLIP=2.0
OCR_DENOISE=true
OCR_DENOISE_H=5
OCR_DENOISE_H_COLOR=5
OCR_SHARPEN=true

# PaddleOCR detector tuning for receipt/invoice
OCR_DET_LIMIT_SIDE_LEN=1536
OCR_DET_LIMIT_TYPE=max
OCR_DET_DB_THRESH=0.25
OCR_DET_DB_BOX_THRESH=0.58
OCR_DET_DB_UNCLIP_RATIO=1.25
OCR_USE_DILATION=false
OCR_DROP_SCORE=0.45
OCR_MAX_BATCH_SIZE=10
OCR_SHOW_LOG=true

# Merge fragmented OCR boxes on the same line
OCR_MERGE_SAME_LINE=true
OCR_MERGE_LINE_Y_RATIO=0.45
OCR_MERGE_GAP_RATIO=1.2
OCR_MERGE_HEIGHT_RATIO=1.8

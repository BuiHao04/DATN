# Model for pretrained baseline
MODEL_ID=nielsr/layoutlmv3-finetuned-funsd

# Paths for pretrained_invoice_baseline.py
# Relative paths are resolved from project dir (src)
PRETRAIN_IMAGE_PATH=data/anh_test.jpg
PRETRAIN_OCR_DEBUG_IMAGE=outputs/ocr_boxes_pretrained.jpg
PRETRAIN_OUTPUT_JSON=outputs/pretrained_invoice_result.json

# OCR engine:
# - paddle: PaddleOCR full
# - vietocr: Paddle detect box + VietOCR recognize text
OCR_ENGINE=paddle

# Optional VietOCR config
VIETOCR_CONFIG=vgg_transformer
# VIETOCR_WEIGHTS=
